.vscode/**
.vscode-test/**
src/**
.gitignore
tsconfig.json
tsconfig.test.json
esbuild.js
scripts/**
out-test/**
out/test/**
out/**/*.test.*
out/**/*.d.ts
docs/**
**/*.map
node_modules/**
*.vsix
.github/**
.eslintrc.json
demo/**
images/diagrams/**
# Belt-and-braces: secrets must never ship in the .vsix even if accidentally
# placed in the repo (also covered by .gitignore so they shouldn't be present).
.env
.env.*
.npmrc
*.pem
*.key
secrets/**
# GIF animations are referenced in README via absolute raw.githubusercontent.com URLs,
# so they don't need to ship in the .vsix. Keep them in the repo for editing, exclude
# from package to keep download size lean.
images/demo/*.gif
images/demo/*.svg
README.md.bak
# Only the two esbuild bundles are loaded at runtime;
# every other compiled .js in out/ is stale tsc emit and is dead weight.
out/autosave.js
out/azureContext.js
out/azureDetect.js
out/contextCompressor.js
out/contextProvider.js
out/contextStore.js
out/embeddings.js
out/health.js
out/memoryTool.js
out/packs.js
out/redactor.js
out/ruleClassifier.js
out/searchCore.js
out/sessionCapture.js
out/sessionsView.js
out/types.js
out/eval.js
out/markdownExport.js
out/repoScope.js
out/validator.js
