.vscode-test/**
src/**
.gitignore
tsconfig.json
tsconfig.test.json
esbuild.js
scripts/**
out-test/**
out/test/**
out/**/*.test.*
out/**/*.d.ts
docs/**
**/*.map
node_modules/**
*.vsix
.github/**
.eslintrc.json
demo/**
images/diagrams/**
# Belt-and-braces: secrets must never ship in the .vsix even if accidentally
# placed in the repo (also covered by .gitignore so they shouldn't be present).
.env
.env.*
.npmrc
*.pem
*.key
secrets/**
# GIF/MP4/SVG demo + marketing assets are referenced in README via absolute
# raw.githubusercontent.com URLs (or live only on GitHub for marketing).
# They never need to ship in the .vsix; excluding keeps the install lean.
images/demo/*.gif
images/demo/*.svg
images/demo/*.mp4
# Root-level marketing artefacts (these slipped into 1.4.9 because the
# rules above only matched images/demo/, not the repo root). Belt-and-braces.
*.mp4
*.gif
ghcp_mem_promo.*
sleek-cinematic-promo.*
README.md.bak
# Only the two esbuild bundles are loaded at runtime;
# every other compiled .js in out/ is stale tsc emit and is dead weight.
out/autosave.js
out/azureContext.js
out/azureDetect.js
out/contextCompressor.js
out/contextProvider.js
out/contextStore.js
out/embeddings.js
out/health.js
