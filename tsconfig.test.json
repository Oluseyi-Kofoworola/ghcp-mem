{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "out-test",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "vscode": ["src/test/__mocks__/vscode.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "out", "out-test"]
}
