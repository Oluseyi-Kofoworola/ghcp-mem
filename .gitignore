out/
out-test/
node_modules/
*.vsix
.vscode-test/

# OS / editor
.DS_Store
Thumbs.db
*.log

# GHCP-MEM auto-injected per-user context (regenerated on every persist)
.github/instructions/session-memory.instructions.md

# Secrets — NEVER commit. Covers .env, .env.local, .env.production, etc.
# .env.example is the only allowed variant (committed templates are fine).
.env
.env.*
!.env.example
src/test/.env
*.pem
*.key
secrets/
.npmrc

# Launch / marketing articles — drafted locally, not version-controlled.
# Keeps the repo focused on code + technical docs; publishing drafts stay
# on the author's workstation.
docs/linkedin-*.md
docs/medium-*.md
docs/*-launch.md
docs/*-article.md

# Personal/private growth planning docs — keep local only.
docs/growth/**

# Marketing assets — drafts, AI-gen prompts, promo renders, working files.
# Everything under docs/marketing/ is local-only by policy; same for any
# *-promo.* media or linkedin/medium/launch named videos that aren't the
# canonical day-01-launch.* set the README depends on.
docs/marketing/**
images/demo/*-promo.mp4
images/demo/*-promo.gif
images/demo/*-promo.svg
images/demo/linkedin-*.mp4
images/demo/linkedin-*.gif
images/demo/medium-*.mp4
images/demo/medium-*.gif
ghcp_mem_promo.*
CLAUDE.md
.cursor/rules
